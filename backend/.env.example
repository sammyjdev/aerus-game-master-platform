# Copy to .env and fill in the values.
#
# Recommended operating modes:
#
# 1. OpenRouter-first validation or production
#    - set AERUS_LOCAL_ONLY=false
#    - configure OPENROUTER_API_KEY
#    - keep Ollama values only as local fallback defaults
#
# 2. Local development on a 12 GB GPU
#    - set AERUS_LOCAL_ONLY=true
#    - prefer qwen2.5:7b-instruct for GM-facing tasks
#    - keep a smaller/faster summarizer model

# Hosted LLM (OpenRouter)
OPENROUTER_API_KEY=

# Local LLM (Ollama)
AERUS_OLLAMA_URL=http://localhost:11434
AERUS_OLLAMA_MODEL=qwen2.5:7b-instruct
AERUS_OLLAMA_TIMEOUT_SECONDS=3
AERUS_LOCAL_ONLY=false
AERUS_DEBUG=false
AERUS_LOG_LEVEL=INFO

# Local development profile
# Recommended for machines such as an RTX 4070 Ti 12 GB where 14B models may
# run in hybrid CPU/GPU mode under Windows.
AERUS_OLLAMA_GM_MODEL=qwen2.5:7b-instruct
AERUS_OLLAMA_EXTRACTOR_MODEL=qwen2.5:7b-instruct
AERUS_OLLAMA_SUMMARIZER_MODEL=phi4:mini
AERUS_OLLAMA_BACKSTORY_MODEL=qwen2.5:7b-instruct
AERUS_OLLAMA_HINT_MODEL=phi4:mini
AERUS_OLLAMA_CONVOCATION_MODEL=phi4:mini

# OpenRouter-first profile example
# AERUS_LOCAL_ONLY=false
# OPENROUTER_API_KEY=sk-or-v1-...
# Keep the Ollama values above only as local fallback defaults.

# Encryption for BYOK keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Password salt (change in production)
PASSWORD_SALT=aerus-salt-change-me

# Paths (optional - defaults exist)
DATABASE_PATH=aerus.db
CONFIG_DIR=config

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173

# Admin secret for protected endpoints (e.g. /admin/invite)
ADMIN_SECRET=change-me-to-a-random-value
