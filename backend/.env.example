# Copy to .env and fill in the values

# LLM (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...

# Local LLM (Ollama)
AERUS_OLLAMA_URL=http://localhost:11434
AERUS_OLLAMA_MODEL=qwen2.5:14b-instruct
AERUS_OLLAMA_TIMEOUT_SECONDS=3
AERUS_LOCAL_ONLY=true
AERUS_DEBUG=false
AERUS_LOG_LEVEL=INFO
AERUS_OLLAMA_GM_MODEL=qwen2.5:14b-instruct
AERUS_OLLAMA_EXTRACTOR_MODEL=qwen2.5:14b-instruct
AERUS_OLLAMA_SUMMARIZER_MODEL=phi4:14b
AERUS_OLLAMA_BACKSTORY_MODEL=qwen2.5:14b-instruct
AERUS_OLLAMA_HINT_MODEL=phi4:14b
AERUS_OLLAMA_CONVOCATION_MODEL=phi4:14b

# Encryption for BYOK keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Password salt (change in production)
PASSWORD_SALT=aerus-salt-change-me

# Paths (optional — defaults exist)
DATABASE_PATH=aerus.db
CONFIG_DIR=config
